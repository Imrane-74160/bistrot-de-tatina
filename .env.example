# ── E-mails (formulaires contact + pré-adhésion) ──────────────────────────────
# Fournisseur principal : Resend (https://resend.com) — gratuit jusqu'à 100 emails/jour.
# TODO: à confirmer client — créer une clé API Resend et l'adresse e-mail de l'asso.
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@bistrot-tatina.fr
CONTACT_FROM_EMAIL=site@bistrot-tatina.fr

# Fallback sans backend : Web3Forms (https://web3forms.com) — coller la clé d'accès.
# Utilisé automatiquement si RESEND_API_KEY est absent.
WEB3FORMS_ACCESS_KEY=

# ── URL publique du site (SEO / OG / sitemap) ─────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bistrot-tatina.fr

# ── Back-office /admin (Decap CMS) — édition en PRODUCTION via GitHub ──────────
# Créer une "OAuth App" GitHub (Settings > Developer settings > OAuth Apps) :
#   - Authorization callback URL = https://VOTRE-SITE/api/callback
# Puis renseigner ces variables (et le repo/base_url dans public/admin/config.yml).
# Inutile pour l'édition LOCALE (npx decap-server).
GITHUB_OAUTH_ID=
GITHUB_OAUTH_SECRET=
